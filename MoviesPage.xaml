<Page x:Class="ChannelsNativeTest.MoviesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Movies" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}"
      PreviewKeyDown="Page_PreviewKeyDown" KeepAlive="True">

    <Page.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="{DynamicResource LiveBorder}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource LiveHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="MovieCardStyle">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8" ClipToBounds="True">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource LiveBorder}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button Content="🏠 Start Page" Margin="0,0,20,0" Click="HomeButton_Click" Style="{StaticResource ModernButton}"/>
                    <TextBlock Text="🎬 MOVIES LIBRARY" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource StatusSuccess}"/>
                </StackPanel>

                <Button x:Name="ToggleFiltersButton" Content="⚙️ Filters" HorizontalAlignment="Right" Click="ToggleFilters_Click"
                        Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border x:Name="FilterBar" Grid.Row="1" Background="{DynamicResource PanelBackground}" CornerRadius="12" Padding="20" Margin="0,0,0,20" Visibility="Collapsed" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,15,0">
                        <TextBox x:Name="SearchBox" Padding="15,12" FontSize="18" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" 
                                 BorderThickness="2" BorderBrush="{DynamicResource BorderBrush}" VerticalContentAlignment="Center" TextChanged="Filter_Changed" />
                        <TextBlock IsHitTestVisible="False" Text="🔍 Search Movies..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0" Foreground="{DynamicResource TextSecondary}" FontSize="18">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ComboBox x:Name="GenreBox" Grid.Column="1" Width="180" Height="50" Margin="0,0,15,0" FontSize="18" VerticalContentAlignment="Center" SelectionChanged="Filter_Changed"/>
                    <ComboBox x:Name="WatchedBox" Grid.Column="2" Width="180" Height="50" Margin="0,0,15,0" FontSize="18" VerticalContentAlignment="Center" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Statuses" IsSelected="True"/>
                        <ComboBoxItem Content="Unwatched Only"/>
                        <ComboBoxItem Content="Watched Only"/>
                    </ComboBox>
                    <ComboBox x:Name="SortBox" Grid.Column="3" Width="180" Height="50" FontSize="18" VerticalContentAlignment="Center" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="A-Z (Alphabetical)" IsSelected="True"/>
                        <ComboBoxItem Content="Newest Added"/>
                        <ComboBoxItem Content="Release Year"/>
                    </ComboBox>
                </Grid>
                <Button Content="✅ Apply Filters" Click="ApplyAndClose_Click" HorizontalAlignment="Right" Margin="0,20,0,0"
                        Background="{DynamicResource LiveBorder}" Foreground="White" FontSize="18" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="MainScroller" Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Focusable="False">
            <ItemsControl x:Name="MoviesItemsControl" Focusable="False">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel HorizontalAlignment="Center" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource MovieCardStyle}" Width="200" Height="340" Click="MovieCard_Click" Tag="{Binding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="300"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                
                                <Image Grid.Row="0" Source="{Binding PosterUrl}" Stretch="UniformToFill" />
                                
                                <Border Grid.Row="1" Background="#DD000000" VerticalAlignment="Bottom" Padding="8,4">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding ReleaseYear}" FontSize="12" Foreground="#AAAAAA" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding DisplayDuration}" FontSize="12" Foreground="#888888"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border x:Name="ModalOverlay" Grid.RowSpan="3" Background="#DD000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Width="800" Height="450" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="30" ShadowDepth="10"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="12,0,0,12" Background="{DynamicResource AppBackground}" ClipToBounds="True">
                        <Image x:Name="ModalImage" Stretch="UniformToFill" VerticalAlignment="Center"/>
                    </Border>

                    <Grid Grid.Column="1" Margin="30">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ModalTitle" Grid.Row="0" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                        
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,20">
                            <TextBlock x:Name="ModalYear" FontSize="16" Foreground="{DynamicResource LiveBorder}" FontWeight="Bold" Margin="0,0,15,0"/>
                            <TextBlock x:Name="ModalDuration" FontSize="16" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>

                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ModalSummary" FontSize="16" Foreground="{DynamicResource HeaderForeground}" TextWrapping="Wrap" LineHeight="24"/>
                        </ScrollViewer>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button x:Name="CloseModalButton" Content="Close" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" Click="CloseModal_Click" Style="{StaticResource ModernButton}"/>
                            <Button x:Name="PlayButton" Content="▶ Play Movie" Background="{DynamicResource LiveBorder}" Foreground="White" Margin="15,0,0,0" Click="PlayButton_Click" Style="{StaticResource ModernButton}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
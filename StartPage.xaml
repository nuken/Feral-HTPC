<Page x:Class="FeralCode.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:fa="http://schemas.awesome.incremented/wpf/xaml/fontawesome.sharp"
      Title="Start Page" Background="{DynamicResource AppBackground}"
      KeepAlive="True">
    
    <Page.Resources>
        <Style TargetType="Button" x:Key="StartMenuButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="4" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource CardHoverBorderBrush}"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/> 
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource LiveHover}"/> 
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,50">
                
                <Image Source="pack://application:,,,/wwwroot/android-chrome-512x512.png" Width="120" Height="120" Margin="0,0,20,0" RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                                      
                <TextBlock Text="FERAL HTPC" FontSize="62" FontWeight="Light" 
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                           FontFamily="Segoe UI Light"/>
                
            </StackPanel>
            
            <WrapPanel HorizontalAlignment="Center" MaxWidth="1000" KeyboardNavigation.DirectionalNavigation="Cycle">
                
                <Button x:Name="BtnLiveTV" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="LiveTv_Click">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconImage Icon="Tv" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="50" Height="50" Margin="0,0,0,15"/>
                        <TextBlock Text="Live TV" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnMovies" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Movies_Click">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconImage Icon="Film" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="50" Height="50" Margin="0,0,0,15"/>
                        <TextBlock Text="Movies" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="BtnShows" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Shows_Click">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconImage Icon="Video" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="50" Height="50" Margin="0,0,0,15"/>
                        <TextBlock Text="TV Shows" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>                
                
                <Button x:Name="BtnApps" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Apps_Click">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconImage Icon="Cubes" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="50" Height="50" Margin="0,0,0,15"/>
                        <TextBlock Text="Apps" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>                
                
                <Button x:Name="BtnMultiview" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Multiview_Click">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconImage Icon="ThLarge" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="50" Height="50" Margin="0,0,0,15"/>
                        <TextBlock Text="Multiview" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>
                
                <Button x:Name="BtnSettings" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Settings_Click">
                    <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <fa:IconImage Icon="Cog" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="50" Height="50" Margin="0,0,0,15"/>
                        <TextBlock Text="Settings" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </WrapPanel>
        </StackPanel>
    </Grid>
</Page>

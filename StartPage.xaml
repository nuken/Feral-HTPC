<Page x:Class="ChannelsNativeTest.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Start Page" Background="{DynamicResource AppBackground}"
      KeepAlive="True">
    
    <Page.Resources>
        <Style TargetType="Button" x:Key="StartMenuButton">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" CornerRadius="12" BorderThickness="4" BorderBrush="Transparent">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource CardHoverBorderBrush}"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/> 
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource LiveHover}"/> 
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,50">
                
                <Image Source="/wwwroot/android-chrome-512x512.png" Width="72" Height="72" Margin="0,0,20,0" 
                       RenderOptions.BitmapScalingMode="HighQuality" VerticalAlignment="Center"/>
                
                <TextBlock Text="CHANNELS HTPC" FontSize="62" FontWeight="Light" 
                           Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"
                           FontFamily="Segoe UI Light"/>
                
            </StackPanel>
            
            <WrapPanel HorizontalAlignment="Center" MaxWidth="1000" KeyboardNavigation.DirectionalNavigation="Cycle">
                <Button Content="📺 Live TV" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="LiveTv_Click"/>
                <Button Content="🎬 Movies" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Movies_Click"/>
                <Button Content="📼 TV Shows" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Shows_Click"/>                
                <Button Content="🌐 Apps" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Apps_Click"/>                
                <Button Content="⚙️ Settings" Width="250" Height="150" Margin="15" Background="{DynamicResource CardBackground}" Style="{StaticResource StartMenuButton}" Click="Settings_Click"/>
            </WrapPanel>
        </StackPanel>
    </Grid>
</Page>
<Page x:Class="ChannelsNativeTest.GuidePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Guide Page" 
      PreviewKeyDown="Page_PreviewKeyDown"
      Focusable="True"
      Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}">
    
    <Page.Resources>
        <Style x:Key="ListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TvGuideFocusStyle" TargetType="Control">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Border BorderThickness="2" BorderBrush="#007ACC" CornerRadius="6" Margin="-2">
                            <Border.Effect>
                                <DropShadowEffect Color="#007ACC" BlurRadius="15" ShadowDepth="0" Opacity="1" />
                            </Border.Effect>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" BorderThickness="2" BorderBrush="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock" x:Key="HeaderText">
            <Setter Property="Foreground" Value="{DynamicResource HeaderForeground}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="{DynamicResource LiveBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>   
        </Grid.RowDefinitions>

        <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                
                <Button Content="🏠 Start Page" Margin="0,0,20,0" Click="HomeButton_Click" Style="{StaticResource ModernButton}"/>
                
                <TextBlock Text="SERVER:" Style="{StaticResource HeaderText}" Margin="0,0,10,0"/>
                <ComboBox x:Name="ServerComboBox" Width="220" Height="34" Margin="0,0,15,0" IsEditable="True" 
                          FontSize="16" Padding="8,0" VerticalContentAlignment="Center" FocusVisualStyle="{StaticResource TvGuideFocusStyle}"/>
                
                <Button Content="Connect" Click="LoadData_Click" Style="{StaticResource ModernButton}"/>
                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="20,0"/>

                <TextBlock Text="COLLECTION:" Style="{StaticResource HeaderText}" Margin="0,0,10,0" x:Name="CollectionLabel" Visibility="Collapsed"/>
                <ComboBox x:Name="CollectionComboBox" Width="180" Height="34" Margin="0,0,15,0" 
                          Visibility="Collapsed" SelectionChanged="CollectionComboBox_SelectionChanged" 
                          FontSize="16" Padding="8,0" VerticalContentAlignment="Center" FocusVisualStyle="{StaticResource TvGuideFocusStyle}"/>

                <TextBlock Text="SEARCH:" Style="{StaticResource HeaderText}" Margin="0,0,10,0" x:Name="SearchLabel" Visibility="Collapsed"/>
                <Border Background="{DynamicResource AppBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="6" Padding="5,0" Visibility="Collapsed" x:Name="SearchBorder">
                    <TextBox x:Name="SearchTextBox" Width="140" Background="Transparent" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" 
                             VerticalAlignment="Center" TextChanged="SearchTextBox_TextChanged" FontSize="14" FocusVisualStyle="{StaticResource TvGuideFocusStyle}"/>
                </Border>

                <Button Content="☀ / 🌙" Margin="20,0,0,0" Padding="10,5" Click="ToggleTheme_Click" Style="{StaticResource ModernButton}" ToolTip="Toggle Light/Dark Theme"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Margin="20,0,0,0" FontSize="13" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <TextBlock Grid.Column="0" Text="CHANNELS" VerticalAlignment="Bottom" Margin="15,0,0,5" FontWeight="Bold" Foreground="{DynamicResource TextSecondary}" FontSize="12"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,5">
                <Button Content="&#x25C0; Earlier" Width="90" Height="30" Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" Margin="0,0,10,0" Click="ScrollLeft_Click"/>
                <Button Content="Later &#x25B6;" Width="90" Height="30" Background="{DynamicResource PanelBackground}" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" Click="ScrollRight_Click"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Border x:Name="ChannelHeaderSpace" Grid.Row="0" Height="35" Margin="0,0,0,5" Background="{DynamicResource AppBackground}"/>
                <ListBox x:Name="ChannelItemsControl" Grid.Row="1" Focusable="False" IsTabStop="False"
                         VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
						 VirtualizingPanel.ScrollUnit="Pixel"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource ListBoxItemStyle}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Height="60" Background="{DynamicResource CardBackground}" CornerRadius="4" Margin="0,5,10,5" Padding="5">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Number}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="{DynamicResource TextPrimary}"/>
                                        <Image Source="{Binding ImageUrl}" Height="26" Stretch="Uniform" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock Grid.Row="1" Text="{Binding Name}" HorizontalAlignment="Center" VerticalAlignment="Bottom" TextTrimming="CharacterEllipsis" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>

            <ScrollViewer Grid.Column="1" x:Name="TimelineScroller" PreviewMouseWheel="TimelineScroller_PreviewMouseWheel" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" Focusable="False" IsTabStop="False">
                <Grid ClipToBounds="True">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <ItemsControl x:Name="TimeHeadersControl" Grid.Row="0" Height="35" Margin="0,0,0,5" Background="{DynamicResource AppBackground}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2,0,0,0" Padding="5,0,0,5">
                                    <TextBlock Text="{Binding}" Foreground="{DynamicResource TextSecondary}" FontSize="14" FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <ListBox x:Name="GuideItemsControl" Grid.Row="1" Focusable="False" IsTabStop="False"
                             VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
							 VirtualizingPanel.ScrollUnit="Pixel"
                             ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             Background="Transparent" BorderThickness="0" ScrollViewer.ScrollChanged="GuideItemsControl_ScrollChanged"
                             ItemContainerStyle="{StaticResource ListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Height="60" Margin="0,5" ClipToBounds="False">
                                    <ItemsControl ItemsSource="{Binding CurrentAirings}" Focusable="False" IsTabStop="False">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4,0,0,0"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="AiringBlock_Click" GotFocus="AiringBlock_GotFocus" RequestBringIntoView="AiringBlock_RequestBringIntoView" Tag="{Binding}" FocusVisualStyle="{StaticResource TvGuideFocusStyle}" Margin="{Binding DynamicMargin}" Padding="0" BorderThickness="0" Background="Transparent" Cursor="Hand">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="EpgBorder" MinWidth="150" Width="{Binding BlockWidth}" Height="50" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6" Padding="8,4" Margin="1,0">
                                                                <Grid Margin="{Binding InnerContentMargin}">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Border Grid.Column="0" Grid.RowSpan="2" Width="4" Background="{Binding CategoryColor}" CornerRadius="2" Margin="0,0,6,0"/>
                                                                    <TextBlock Grid.Column="1" Grid.Row="0" Text="{Binding DisplayTitle}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Top" TextTrimming="CharacterEllipsis"/>
                                                                    <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding DisplaySummary}" Foreground="{DynamicResource TextSecondary}" FontSize="11" VerticalAlignment="Top" TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="EpgBorder" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                                                                    <Setter TargetName="EpgBorder" Property="BorderBrush" Value="{DynamicResource CardHoverBorderBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsKeyboardFocused" Value="True">
                                                                    <Setter TargetName="EpgBorder" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                                                                    <Setter TargetName="EpgBorder" Property="BorderBrush" Value="{DynamicResource CardHoverBorderBrush}"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsAiringNow}" Value="True">
                                                                    <Setter TargetName="EpgBorder" Property="Background" Value="{DynamicResource LiveBackground}"/>
                                                                    <Setter TargetName="EpgBorder" Property="BorderBrush" Value="{DynamicResource LiveBorder}"/>
                                                                </DataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsAiringNow}" Value="True"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsMouseOver}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter TargetName="EpgBorder" Property="Background" Value="{DynamicResource LiveHover}"/>
                                                                </MultiDataTrigger>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsAiringNow}" Value="True"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsKeyboardFocused}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter TargetName="EpgBorder" Property="Background" Value="{DynamicResource LiveHover}"/>
                                                                </MultiDataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </ScrollViewer>
        </Grid>

        <Border x:Name="ModalOverlay" Grid.RowSpan="3" Background="#CC000000" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Width="750" Height="400" VerticalAlignment="Center" HorizontalAlignment="Center" KeyboardNavigation.DirectionalNavigation="Cycle" KeyboardNavigation.TabNavigation="Cycle">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="25" ShadowDepth="8"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="260"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="12,0,0,12" Background="{DynamicResource AppBackground}" ClipToBounds="True">
                        <Image x:Name="ModalImage" Stretch="UniformToFill" VerticalAlignment="Center"/>
                    </Border>
                    
                    <Border x:Name="ModalCategoryBar" Grid.Column="0" Width="6" HorizontalAlignment="Left" Background="Transparent" CornerRadius="12,0,0,12"/>

                    <Grid Grid.Column="1" Margin="30,25,30,25">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ModalTitle" Grid.Row="0" Text="Show Title" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="ModalMetaData" Grid.Row="1" Margin="0,8,0,0" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource LiveBorder}" TextWrapping="Wrap"/>
                        <TextBlock x:Name="ModalTime" Grid.Row="1" Margin="0,30,0,15" FontSize="13" Foreground="{DynamicResource TextSecondary}"/>

                        <ScrollViewer Grid.Row="2" Margin="0,5,0,15" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="ModalSummary" FontSize="15" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" LineHeight="22"/>
                        </ScrollViewer>

                        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="CloseModalButton" Content="Close" Width="100" Height="40" Background="{DynamicResource CardHoverBackground}" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" Click="CloseModal_Click" Style="{StaticResource ModernButton}"/>
                            <Button x:Name="WatchButton" Content="▶ Watch Live" Width="140" Height="40" Background="{DynamicResource LiveBorder}" Foreground="White" BorderThickness="0" Margin="10,0,0,0" Visibility="Collapsed" Click="WatchButton_Click" Style="{StaticResource ModernButton}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Border>
    </Grid>
</Page>
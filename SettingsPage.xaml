<Page x:Class="ChannelsNativeTest.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}"
      PreviewKeyDown="Page_PreviewKeyDown" KeepAlive="True" Focusable="True">
    <Page.Resources>
	    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#007ACC"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#007ACC"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="White"/>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="{DynamicResource LiveBorder}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource LiveHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox" x:Key="BigCheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="OuterBorder" BorderBrush="Transparent" BorderThickness="3" CornerRadius="4" Padding="5">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="Box" Width="24" Height="24" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="4" Background="{DynamicResource CardBackground}" VerticalAlignment="Center">
                                    <TextBlock x:Name="CheckMark" Text="✔" Foreground="{DynamicResource StatusSuccess}" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource LiveBorder}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
		<Style TargetType="ComboBox">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/> 
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton" 
                                          Background="{TemplateBinding Background}" 
                                          BorderBrush="{TemplateBinding BorderBrush}" 
                                          BorderThickness="{TemplateBinding BorderThickness}" 
                                          Focusable="false"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                            <Path Fill="{DynamicResource TextPrimary}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0" Data="M 0 0 L 5 5 L 10 0 Z"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            
                            <ContentPresenter IsHitTestVisible="False" Margin="15,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>
                            
                            <Popup x:Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" CornerRadius="8" Margin="0,5,0,0" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="250">
                                        <StackPanel IsItemsHost="True" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource LiveBorder}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
		<Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource LiveHover}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource LiveBorder}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
		
    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,30">
            <StackPanel Orientation="Horizontal">
                <Button Content="🏠 Back" Margin="0,0,20,0" Click="HomeButton_Click" Style="{StaticResource ModernButton}"/>
                <TextBlock Text="⚙️ SYSTEM SETTINGS" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" HorizontalAlignment="Left" Width="600">
            
            <TextBlock Text="Mobile Remote Control URL" FontSize="16" Foreground="{DynamicResource TextSecondary}" Margin="5,0,0,5"/>
            <TextBox x:Name="LocalRemoteUrlBox" FontSize="18" Padding="10" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource StatusConnecting}" BorderBrush="Transparent" BorderThickness="0" Margin="0,0,0,30" IsReadOnly="True"/>
            
            <TextBlock Text="DVR Server IP Address (Optional)" FontSize="16" Foreground="{DynamicResource TextSecondary}" Margin="5,0,0,5"/>
            <TextBox x:Name="ServerIpTextBox" FontSize="18" Padding="10" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2" Margin="0,0,0,30"/>

            <TextBlock Text="Playback Preferences" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,15"/>
            <CheckBox x:Name="AutoSkipCheckBox" Content="Auto-Skip Commercials in Movies" Style="{StaticResource BigCheckBox}"/>
            
            <CheckBox x:Name="FullscreenCheckBox" Content="Start Players in Fullscreen Mode" Style="{StaticResource BigCheckBox}"/>

            <TextBlock Text="Guide Preferences" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,30,0,15"/>
            <StackPanel Orientation="Horizontal" Margin="5,0,0,10">
                <TextBlock Text="Hours of Guide Data to Load:" FontSize="18" Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <ComboBox x:Name="GuideDurationBox" FontSize="18" Width="150" Padding="10,5">
                    <ComboBoxItem Content="4 Hours" Tag="4"/>
                    <ComboBoxItem Content="8 Hours" Tag="8"/>
                    <ComboBoxItem Content="12 Hours" Tag="12"/>
                </ComboBox>
            </StackPanel>

            <TextBlock Text="Appearance" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,30,0,15"/>
            <CheckBox x:Name="LightModeCheckBox" Content="Enable Light Theme (Global)" Style="{StaticResource BigCheckBox}"/>

            <TextBlock Text="External Streaming Apps" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" Margin="0,40,0,15"/>
            
            <Border Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Show / Movie Title" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="StreamTitleBox" FontSize="16" Padding="8" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Service" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <ComboBox x:Name="StreamServiceBox" FontSize="16" Padding="8" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}" BorderThickness="0">
                            <ComboBoxItem Content="Netflix" IsSelected="True"/>
                            <ComboBoxItem Content="Disney+"/>
                            <ComboBoxItem Content="Hulu"/>
                            <ComboBoxItem Content="Prime Video"/>
                            <ComboBoxItem Content="Custom URI"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Deep Link ID / URL" Foreground="{DynamicResource TextSecondary}" FontSize="12" Margin="0,0,0,4"/>
                        <TextBox x:Name="StreamIdBox" FontSize="16" Padding="8" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="2"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="➕ Add" VerticalAlignment="Bottom" Click="AddStream_Click" 
                            Background="{DynamicResource LiveBorder}" Foreground="White" FontSize="14" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand" Height="41"/>
                </Grid>
            </Border>

            <StackPanel x:Name="SavedStreamsList"/>

        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="SaveStatusText" FontSize="16" Foreground="{DynamicResource StatusSuccess}" VerticalAlignment="Center" Margin="0,0,20,0" Visibility="Collapsed" Text="✔ Settings Saved!"/>
            <Button x:Name="SaveButton" Content="💾 Save Settings" Click="SaveButton_Click" Style="{StaticResource ModernButton}" Width="200"/>
        </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
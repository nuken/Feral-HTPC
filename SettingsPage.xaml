<Page x:Class="ChannelsNativeTest.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Settings" Background="#121212" Foreground="White"
      PreviewKeyDown="Page_PreviewKeyDown" KeepAlive="True" Focusable="True">
    <Page.Resources>
        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="#005A9E"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#FFD700"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox" x:Key="BigCheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="OuterBorder" BorderBrush="Transparent" BorderThickness="3" CornerRadius="4" Padding="5">
                            <StackPanel Orientation="Horizontal">
                                <Border x:Name="Box" Width="24" Height="24" BorderBrush="#888" BorderThickness="2" CornerRadius="4" Background="#222" VerticalAlignment="Center">
                                    <TextBlock x:Name="CheckMark" Text="✔" Foreground="#00FF00" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                                </Border>
                                <ContentPresenter Margin="15,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="Box" Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="OuterBorder" Property="BorderBrush" Value="#FFD700"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
		
    </Page.Resources>
	<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,30">
            <StackPanel Orientation="Horizontal">
                <Button Content="🏠 Back" Margin="0,0,20,0" Click="HomeButton_Click" Style="{StaticResource ModernButton}"/>
                <TextBlock Text="⚙️ SYSTEM SETTINGS" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="#AAAAAA"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="1" HorizontalAlignment="Left" Width="600">
            
            <TextBlock Text="DVR Server IP Address (Optional)" FontSize="16" Foreground="#AAAAAA" Margin="5,0,0,5"/>
            <TextBox x:Name="ServerIpTextBox" FontSize="18" Padding="10" Background="#222" Foreground="White" BorderBrush="#555" BorderThickness="2" Margin="0,0,0,30"/>

            <TextBlock Text="Playback Preferences" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>
            <CheckBox x:Name="AutoSkipCheckBox" Content="Auto-Skip Commercials in Movies" Style="{StaticResource BigCheckBox}"/>

            <TextBlock Text="Appearance" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,30,0,15"/>
            <CheckBox x:Name="LightModeCheckBox" Content="Enable Light Theme (Guide Page)" Style="{StaticResource BigCheckBox}"/>

            <TextBlock Text="External Streaming Apps" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,40,0,15"/>
            
            <Border Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Show / Movie Title" Foreground="#888" FontSize="12"/>
                        <TextBox x:Name="StreamTitleBox" FontSize="16" Padding="8" Background="#333" Foreground="White" BorderThickness="0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="0,0,10,0">
                        <TextBlock Text="Service" Foreground="#888" FontSize="12"/>
                        <ComboBox x:Name="StreamServiceBox" FontSize="16" Padding="8" Background="#666" Foreground="#888" BorderThickness="0">
                            <ComboBoxItem Content="Netflix" IsSelected="True"/>
                            <ComboBoxItem Content="Disney+"/>
                            <ComboBoxItem Content="Hulu"/>
                            <ComboBoxItem Content="Prime Video"/>
                            <ComboBoxItem Content="Custom URI"/>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Margin="0,0,10,0">
                        <TextBlock Text="Deep Link ID / URL" Foreground="#888" FontSize="12"/>
                        <TextBox x:Name="StreamIdBox" FontSize="16" Padding="8" Background="#333" Foreground="White" BorderThickness="0"/>
                    </StackPanel>

                    <Button Grid.Column="3" Content="➕ Add" VerticalAlignment="Bottom" Click="AddStream_Click" 
                            Background="#007ACC" Foreground="White" FontSize="14" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                </Grid>
            </Border>

            <StackPanel x:Name="SavedStreamsList"/>

        </StackPanel>
		
		

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <TextBlock x:Name="SaveStatusText" FontSize="16" Foreground="#00FF00" VerticalAlignment="Center" Margin="0,0,20,0" Visibility="Collapsed" Text="✔ Settings Saved!"/>
            <Button x:Name="SaveButton" Content="💾 Save Settings" Click="SaveButton_Click" Style="{StaticResource ModernButton}" Width="200"/>
        </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
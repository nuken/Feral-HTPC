<Page x:Class="FeralCode.ShowsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="TV Shows" Background="{DynamicResource AppBackground}" Foreground="{DynamicResource TextPrimary}"
      PreviewKeyDown="Page_PreviewKeyDown" KeepAlive="True">

    <Page.Resources>
	
	    <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="{DynamicResource LiveBorder}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource LiveHover}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="PosterButton">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="350"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="0" ClipToBounds="True">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource LiveBorder}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="EpisodeButton">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="{DynamicResource CardHoverBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
		<Style TargetType="Button" x:Key="SeasonButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource StatusConnecting}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> 
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource PanelBackground}" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="BackButton" Content="🏠 Home" Margin="0,0,20,0" Click="BackButton_Click" 
                            Background="{DynamicResource LiveBorder}" Foreground="White" FontSize="16" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                    <TextBlock x:Name="PageTitle" Text="🍿 TV SHOWS" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>
                
                <Button x:Name="ToggleFiltersButton" Content="⚙️ Filters" HorizontalAlignment="Right" Click="ToggleFilters_Click"
                        Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" FontSize="16" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border x:Name="FilterBar" Grid.Row="1" Background="{DynamicResource PanelBackground}" CornerRadius="12" Padding="20" Margin="0,0,0,20" Visibility="Collapsed" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,15,0">
                        <TextBox x:Name="SearchBox" Padding="15,12" FontSize="18" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" 
                                 BorderThickness="2" BorderBrush="{DynamicResource BorderBrush}" VerticalContentAlignment="Center" TextChanged="Filter_Changed" />
                        
                        <TextBlock IsHitTestVisible="False" Text="🔍 Search Shows..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0" Foreground="{DynamicResource TextSecondary}" FontSize="18">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ComboBox x:Name="GenreBox" Grid.Column="1" Width="180" Height="50" Margin="0,0,15,0" FontSize="18" 
                              VerticalContentAlignment="Center" SelectionChanged="Filter_Changed"/>
                    
                    <ComboBox x:Name="WatchedBox" Grid.Column="2" Width="180" Height="50" Margin="0,0,15,0" FontSize="18" 
                              VerticalContentAlignment="Center" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Statuses" IsSelected="True"/>
                        <ComboBoxItem Content="Unwatched Only"/>
                        <ComboBoxItem Content="Watched Only"/>
                    </ComboBox>

                    <ComboBox x:Name="SortBox" Grid.Column="3" Width="180" Height="50" FontSize="18" 
                              VerticalContentAlignment="Center" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="A-Z (Alphabetical)" IsSelected="True"/>
                        <ComboBoxItem Content="Newest Added"/>
                        <ComboBoxItem Content="Release Year"/>
						<ComboBoxItem Content="Recently Updated"/>
                    </ComboBox>
                </Grid>

                <Button Content="✅ Apply Filters" Click="ApplyAndClose_Click" HorizontalAlignment="Right" Margin="0,20,0,0"
                        Background="{DynamicResource LiveBorder}" Foreground="White" FontSize="18" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="ShowsScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Hidden" Focusable="False">
            <WrapPanel x:Name="ShowsWrapPanel" HorizontalAlignment="Center" KeyboardNavigation.DirectionalNavigation="Cycle" />
        </ScrollViewer>

        <Grid x:Name="EpisodesView" Grid.Row="2" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/> <ColumnDefinition Width="180"/> <ColumnDefinition Width="*"/>   </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Image x:Name="SelectedShowImage" Width="260" Height="360" Stretch="UniformToFill" Margin="0,0,0,15"/>
                <TextBlock x:Name="SelectedShowTitle" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock x:Name="SelectedShowCount" FontSize="14" Foreground="{DynamicResource TextSecondary}" Margin="0,0,0,15"/>

                <StackPanel x:Name="ModalExtendedData" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Border x:Name="RatingBorder" Background="{DynamicResource LiveBorder}" CornerRadius="4" Padding="6,2" Margin="0,0,10,0">
                            <TextBlock x:Name="ModalRating" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock x:Name="ModalTags" FontSize="13" Foreground="{DynamicResource TextSecondary}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                    <TextBlock x:Name="ModalCast" FontSize="13" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" LineHeight="18"/>
                </StackPanel>
            </StackPanel>

            <Border Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0" Margin="0,0,20,0" Padding="0,0,10,0">
                <ScrollViewer x:Name="SeasonsScrollViewer" VerticalScrollBarVisibility="Hidden" Focusable="False">
                    <StackPanel x:Name="SeasonsStackPanel"/>
                </ScrollViewer>
            </Border>

            <ScrollViewer x:Name="EpisodesScrollViewer" Grid.Column="2" VerticalScrollBarVisibility="Hidden" Focusable="False">
                <StackPanel x:Name="EpisodesStackPanel" Margin="0,0,10,0"/>
            </ScrollViewer>
        </Grid>
        <Border x:Name="EpisodeActionOverlay" Grid.RowSpan="3" Background="#DD000000" Visibility="Collapsed" Panel.ZIndex="100">
            <Border Background="{DynamicResource PanelBackground}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12" Width="500" Height="250" VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect Color="Black" Opacity="0.5" BlurRadius="30" ShadowDepth="10"/>
                </Border.Effect>
                <StackPanel Margin="30" VerticalAlignment="Center">
                    <TextBlock x:Name="EpisodeActionTitle" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock x:Name="EpisodeActionSubtitle" FontSize="16" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,30"/>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Cancel" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" Click="CancelEpisodeAction_Click" Style="{StaticResource ModernButton}" Margin="0,0,10,0"/>
                        <Button x:Name="EpStartOverButton" Content="⏮ Start Over" Background="{DynamicResource CardBackground}" Foreground="{DynamicResource TextPrimary}" Click="EpStartOverButton_Click" Style="{StaticResource ModernButton}" Margin="0,0,10,0"/>
                        <Button x:Name="EpResumeButton" Content="▶ Resume" Background="{DynamicResource LiveBorder}" Foreground="White" Click="EpResumeButton_Click" Style="{StaticResource ModernButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
        <TextBlock x:Name="LoadingText" Grid.Row="2" Text="⏳ Loading Library..." FontSize="24" Foreground="{DynamicResource TextSecondary}" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
    </Grid>
</Page>
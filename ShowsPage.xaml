<Page x:Class="ChannelsNativeTest.ShowsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="TV Shows" Background="#121212" Foreground="White"
      PreviewKeyDown="Page_PreviewKeyDown" KeepAlive="True">

    <Page.Resources>
        <Style TargetType="Button" x:Key="PosterButton">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="Height" Value="340"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="4"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12" Padding="0" ClipToBounds="True">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#007ACC"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="EpisodeButton">
            <Setter Property="Background" Value="#1E1E1E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BgBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="#FFD700"/>
                                <Setter TargetName="BgBorder" Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <Button x:Name="BackButton" Content="🏠 Home" Margin="0,0,20,0" Click="BackButton_Click" 
                            Background="#007ACC" Foreground="White" FontSize="16" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
                    <TextBlock x:Name="PageTitle" Text="🍿 TV SHOWS" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="#AAAAAA"/>
                </StackPanel>
                
                <Button x:Name="ToggleFiltersButton" Content="⚙️ Filters" HorizontalAlignment="Right" Click="ToggleFilters_Click"
                        Background="#333" Foreground="White" FontSize="16" FontWeight="Bold" Padding="15,8" BorderThickness="0" Cursor="Hand"/>
            </Grid>
        </Border>

        <Border x:Name="FilterBar" Grid.Row="1" Background="#1A1A1A" CornerRadius="12" Padding="20" Margin="0,0,0,20" Visibility="Collapsed" BorderThickness="1" BorderBrush="#333">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0" Margin="0,0,15,0">
                        <TextBox x:Name="SearchBox" Padding="15,12" FontSize="18" Background="#252526" Foreground="White" 
                                 BorderThickness="2" BorderBrush="#444" VerticalContentAlignment="Center" TextChanged="Filter_Changed" />
                        
                        <TextBlock IsHitTestVisible="False" Text="🔍 Search Shows..." VerticalAlignment="Center" HorizontalAlignment="Left" Margin="15,0,0,0" Foreground="#888" FontSize="18">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <ComboBox x:Name="GenreBox" Grid.Column="1" Width="180" Height="50" Margin="0,0,15,0" FontSize="18" 
                              VerticalContentAlignment="Center" SelectionChanged="Filter_Changed"/>
                    
                    <ComboBox x:Name="WatchedBox" Grid.Column="2" Width="180" Height="50" Margin="0,0,15,0" FontSize="18" 
                              VerticalContentAlignment="Center" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="All Statuses" IsSelected="True"/>
                        <ComboBoxItem Content="Unwatched Only"/>
                        <ComboBoxItem Content="Watched Only"/>
                    </ComboBox>

                    <ComboBox x:Name="SortBox" Grid.Column="3" Width="180" Height="50" FontSize="18" 
                              VerticalContentAlignment="Center" SelectionChanged="Filter_Changed">
                        <ComboBoxItem Content="A-Z (Alphabetical)" IsSelected="True"/>
                        <ComboBoxItem Content="Newest Added"/>
                        <ComboBoxItem Content="Release Year"/>
                    </ComboBox>
                </Grid>

                <Button Content="✅ Apply Filters" Click="ApplyAndClose_Click" HorizontalAlignment="Right" Margin="0,20,0,0"
                        Background="#007ACC" Foreground="White" FontSize="18" FontWeight="Bold" Padding="25,12" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="ShowsScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Hidden" Focusable="False">
            <WrapPanel x:Name="ShowsWrapPanel" HorizontalAlignment="Center"/>
        </ScrollViewer>

        <Grid x:Name="EpisodesView" Grid.Row="2" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                <Image x:Name="SelectedShowImage" Width="280" Height="400" Stretch="UniformToFill" Margin="0,0,0,15"/>
                <TextBlock x:Name="SelectedShowTitle" FontSize="24" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,10"/>
                <TextBlock x:Name="SelectedShowCount" FontSize="16" Foreground="#AAAAAA"/>
            </StackPanel>

            <ScrollViewer x:Name="EpisodesScrollViewer" Grid.Column="1" VerticalScrollBarVisibility="Hidden" Focusable="False">
                <StackPanel x:Name="EpisodesStackPanel" Margin="10,0,0,0"/>
            </ScrollViewer>
        </Grid>

        <TextBlock x:Name="LoadingText" Grid.Row="2" Text="⏳ Loading Library..." FontSize="24" Foreground="#888888" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
    </Grid>
</Page>